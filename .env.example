# Entorno
NODE_ENV=development # cambiar: production o development

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development  # o production

# Base de datos PostgreSQL
POSTGRES_USER=app_user
POSTGRES_PASSWORD=TuPassword
POSTGRES_DB=app_db
DB_HOST=db # o la IP ej: 172.18.0.2
DB_PORT=5432
DB_USER=app_user
DB_PASSWORD=TuPassword  # Cambiar por una contraseña segura y única por proyecto (usa secrets manager en prod)
DB_NAME=app_db
DB_SCHEMA=public

# JWT
SECRET_JWT_KEY=your-very-long-and-secure-secret-here-min-128-chars
SECRET_REFRESH_JWT_KEY=your-very-long-and-secure-refresh-secret-here-min-128-chars
JWT_ACCESS_EXPIRY=10m
JWT_REFRESH_EXPIRY=7d

# CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000 # Agregar dominios reales en producción, separados por coma

# Tu URL de ngrok (SIN la barra / al final)
API_BASE_URL=https://unforsworn-skiagraphical-claretta.ngrok-free.dev # apiBaseUrl
APP_URL="http://localhost:5173" # frontendUrl

# Mailtrap Config
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="Tu_User"
SMTP_PASS="Tu_Password"

# Email Settings
EMAIL_FROM="App Support <noreply@app.com>"

# Pilar de Seguridad: Pepper para contraseñas
# Genera una cadena aleatoria compleja (ej: 32+ caracteres)
PASSWORD_PEPPER="App_SecurE_StronG_PeppeR_2026_!"

# Clave Secreta de Google reCAPTCHA
RECAPTCHA_SECRET_KEY=Tu_Secret_Key
